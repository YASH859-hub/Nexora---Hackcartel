# Single Nexora env file (repo root). Loaded by Vite (GEMINI, VITE_*) and backend (Twilio, PORT, briefing).

# --- Frontend / Vite ---
GEMINI_API_KEY=your_gemini_key
APP_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# SUPABASE: Database Configuration
# Get these from your Supabase project settings at https://app.supabase.com
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Google OAuth 2.0 Client ID (required for Gmail OAuth popup)
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"

# Google API key / Gemini key (used for LLM extraction)
VITE_GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# DeepSeek API key (used for email action-item extraction)
VITE_DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
VITE_DEEPSEEK_MODEL="deepseek-chat"

# --- Backend / Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Production: whatsapp:+1XXXXXXXXXX (must be WhatsApp-approved in Twilio). Sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+16812013984

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Daily per-user briefings ---
# Send WhatsApp briefings to all subscribers when the server starts (default on). Set false to skip (e.g. local dev).
BRIEFING_SEND_ON_STARTUP=true
# Milliseconds to wait after listen before sending (Twilio ready / avoid race)
BRIEFING_STARTUP_DELAY_MS=2500
# IANA timezone for 8:00 AM sends (optional)
BRIEFING_TZ=
# Optional absolute path; default stores JSON under backend/data/
BRIEFING_DATA_DIR=

# Optional default recipient for POST /api/whatsapp/send when body omits to/phoneNumber
DEFAULT_USER_PHONE=whatsapp:+10000000000

# First line of every WhatsApp (preview). Chat list name = WhatsApp Business profile in Twilio / Meta.
WHATSAPP_BRAND_NAME=Nexora
